generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATIONS_AGENT
  COMPLIANCE_REVIEWER
  TEAM_LEAD
  ADMIN
}

enum MerchantCategory {
  RETAIL
  FOOD_AND_BEVERAGE
  DIGITAL_SERVICES
}

enum ApplicationStatus {
  DRAFT
  PENDING_DOCUMENTS
  VERIFICATION_IN_PROGRESS
  READY_FOR_REVIEW
  IN_REVIEW
  EXCEPTION_REVIEW_REQUIRED
  SENT_BACK
  APPROVED
  REJECTED
  WITHDRAWN
  AUTO_APPROVED
}

enum RiskStatus {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChecklistOwner {
  OPERATIONS
  MERCHANT
  REVIEWER
  SYSTEM
}

enum ChecklistItemStatus {
  NOT_STARTED
  PENDING
  UPLOADED
  VERIFIED
  FAILED
  WAIVED
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  OCR_COMPLETE
  VERIFICATION_PASSED
  VERIFICATION_FAILED
  TAMPERED
  MANUAL_REVIEW_REQUIRED
  REJECTED
  VERIFIED
}

enum VerificationStatus {
  QUEUED
  RUNNING
  PASSED
  FAILED
  NEEDS_REVIEW
  UNSUPPORTED
}

enum AuditActorType {
  USER
  SYSTEM
  INTEGRATION
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  role                 Role
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  assignedApplications MerchantApplication[] @relation("AssignedAgent")
  reviewedApplications MerchantApplication[] @relation("AssignedReviewer")
  uploadedDocuments    Document[]
  waivers              Waiver[]
  auditEvents          AuditEvent[]
  statusChanges        ApplicationStatusEvent[]
}

model MerchantApplication {
  id                    String                   @id @default(cuid())
  referenceId           String                   @unique
  legalName             String
  displayName           String
  category              MerchantCategory
  businessConstitution  String
  gstNumber             String?
  pan                   String?
  primaryContactName    String
  primaryContactEmail   String
  primaryContactPhone   String
  registeredAddress     String
  operatingAddress      String?
  onboardingSource      String
  status                ApplicationStatus        @default(DRAFT)
  riskStatus            RiskStatus               @default(LOW)
  confidenceScore       Decimal?                 @db.Decimal(5, 2)
  slaDueAt              DateTime?
  submittedAt           DateTime?
  decidedAt             DateTime?
  assignedAgentId       String?
  assignedReviewerId    String?
  checklistTemplateId   String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  assignedAgent         User?                    @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  assignedReviewer      User?                    @relation("AssignedReviewer", fields: [assignedReviewerId], references: [id])
  checklistTemplate     ChecklistTemplate?       @relation(fields: [checklistTemplateId], references: [id])
  checklistItems        ApplicationChecklistItem[]
  documents             Document[]
  verificationRuns      VerificationRun[]
  waivers               Waiver[]
  auditEvents           AuditEvent[]
  statusEvents          ApplicationStatusEvent[]

  @@index([status, category])
  @@index([assignedAgentId])
  @@index([assignedReviewerId])
}

model ChecklistTemplate {
  id           String             @id @default(cuid())
  name         String
  category     MerchantCategory
  version      Int                @default(1)
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  items        ChecklistTemplateItem[]
  applications MerchantApplication[]

  @@unique([category, version])
}

model ChecklistTemplateItem {
  id                  String            @id @default(cuid())
  templateId          String
  title               String
  description         String?
  isRequired          Boolean           @default(true)
  documentType        String?
  owner               ChecklistOwner    @default(OPERATIONS)
  automationSupported Boolean           @default(false)
  verificationService String?
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  template            ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model ApplicationChecklistItem {
  id                  String              @id @default(cuid())
  applicationId       String
  title               String
  description         String?
  isRequired          Boolean             @default(true)
  documentType        String?
  owner               ChecklistOwner      @default(OPERATIONS)
  automationSupported Boolean             @default(false)
  status              ChecklistItemStatus @default(NOT_STARTED)
  confidenceScore     Decimal?            @db.Decimal(5, 2)
  reviewerNotes       String?
  rejectionReason     String?
  sortOrder           Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  application         MerchantApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documents           Document[]
  waivers             Waiver[]

  @@index([applicationId, status])
}

model Document {
  id              String                    @id @default(cuid())
  applicationId   String
  checklistItemId String?
  fileName        String
  fileKey         String
  mimeType        String
  documentType    String
  version         Int                       @default(1)
  status          DocumentStatus            @default(UPLOADED)
  rejectionReason String?
  uploadedById    String
  uploadedAt      DateTime                  @default(now())
  application     MerchantApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  checklistItem   ApplicationChecklistItem? @relation(fields: [checklistItemId], references: [id])
  uploadedBy      User                      @relation(fields: [uploadedById], references: [id])
  verificationRuns VerificationRun[]

  @@index([applicationId, documentType])
  @@index([checklistItemId])
}

model VerificationRun {
  id                  String              @id @default(cuid())
  applicationId       String
  documentId          String?
  serviceName         String
  status              VerificationStatus  @default(QUEUED)
  confidenceScore     Decimal?            @db.Decimal(5, 2)
  extractedFields     Json?
  mismatchIndicators  Json?
  retryRecommendation String?
  escalationReason    String?
  rawResponse         Json?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime            @default(now())
  application         MerchantApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  document            Document?           @relation(fields: [documentId], references: [id])

  @@index([applicationId, status])
}

model Waiver {
  id              String                    @id @default(cuid())
  applicationId   String
  checklistItemId String
  reason          String
  approvedById    String
  approvedAt      DateTime                  @default(now())
  application     MerchantApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  checklistItem   ApplicationChecklistItem  @relation(fields: [checklistItemId], references: [id])
  approvedBy      User                      @relation(fields: [approvedById], references: [id])

  @@index([applicationId])
  @@index([checklistItemId])
}

model ApplicationStatusEvent {
  id            String              @id @default(cuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  reason        String?
  actorId       String?
  createdAt     DateTime            @default(now())
  application   MerchantApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actor         User?               @relation(fields: [actorId], references: [id])

  @@index([applicationId, createdAt])
}

model AuditEvent {
  id            String              @id @default(cuid())
  applicationId String?
  actorId       String?
  actorType     AuditActorType      @default(USER)
  action        String
  entityType    String
  entityId      String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  application   MerchantApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actor         User?               @relation(fields: [actorId], references: [id])

  @@index([applicationId, createdAt])
  @@index([entityType, entityId])
}
